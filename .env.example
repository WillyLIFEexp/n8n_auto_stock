# =============================================================================
# n8n_auto_stock — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# Never commit your .env file to version control.
# =============================================================================


# -----------------------------------------------------------------------------
# n8n Configuration
# -----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# Publicly accessible URL where n8n is hosted (used for webhooks)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# n8n encryption key — generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Timezone (e.g. Asia/Kuala_Lumpur, Asia/Singapore, UTC)
GENERIC_TIMEZONE=Asia/Kuala_Lumpur


# -----------------------------------------------------------------------------
# Python / FastAPI Service
# -----------------------------------------------------------------------------
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# Secret key for JWT / session signing — generate with: openssl rand -hex 32
SECRET_KEY=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5678



# -----------------------------------------------------------------------------
# Database (optional — if storing historical data)
# -----------------------------------------------------------------------------
# Examples: postgresql://user:password@host:5432/dbname
#           sqlite:///./data.db
DATABASE_URL=sqlite:///./stock_data.db

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=n8n_stock
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme


# -----------------------------------------------------------------------------
# Redis (optional — for caching / task queue)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0


# -----------------------------------------------------------------------------
# Nginx / SSL
# -----------------------------------------------------------------------------
# Domain name used in nginx config and certbot
DOMAIN=yourdomain.com
SSL_EMAIL=your@email.com


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
